# ─── À copier en .env et adapter ───────────────────────────────────────────────

# Domaine du VPS (sans https://)
YOUR_DOMAIN=gmail.mondomaine.com

# URL de l'application (utilisée par FastAPI pour CORS et les redirects OAuth2)
FRONTEND_URL=https://gmail.mondomaine.com

# Redirect URI OAuth2 — doit correspondre exactement à Google Cloud Console
# Format : https://VOTRE_DOMAINE/auth/callback
OAUTH_REDIRECT_URI=https://gmail.mondomaine.com/auth/callback

# Fichier credentials.json (monté en lecture seule dans le container)
GMAIL_CREDENTIALS_FILE=/app/credentials.json

# Chemin token et base de données (dans le volume Docker /data)
GMAIL_TOKEN_FILE=/data/token.json
DB_PATH=/data/gmail_cache.db

# Nombre max d'emails à analyser (0 = sans limite)
MAX_EMAILS=10000

# ── Sécurité application ──────────────────────────────────────────────────────
# Clé secrète pour signer les cookies de session (générer avec : python3 -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=CHANGEZ_MOI_AVEC_UNE_VALEUR_ALEATOIRE

# Hash du mot de passe d'accès à l'application
# Générer avec : cd backend && python generate_password.py
APP_PASSWORD_HASH=
